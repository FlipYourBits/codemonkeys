{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/branch_guard.py"
        }]
      },
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py"
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|Read",
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_use.py"
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "Edit(*.py)|Write(*.py)",
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use.py"
        }]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use_failure.py"
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/stop.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/stop_memory.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py"
        }]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/permission_request.py"
        }]
      }
    ],
    "Notification": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/notification.py"
        }]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/subagent_start.py"
        }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/subagent_stop.py"
        }]
      }
    ]
  }
}
